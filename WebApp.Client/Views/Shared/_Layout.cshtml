<!DOCTYPE html>
<html lang="en" class="h-100"> @* Indispensable pour que le min-vh-100 fonctionne *@
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebApp.Client</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebApp.Client.styles.css" asp-append-version="true" />

    <script src="~/dist/theme-init.js" asp-append-version="true"></script>
</head>

<body class="h-100"> @* On s'assure que le body prend toute la hauteur *@
    <div id="theme-wrapper" class="d-flex flex-column min-vh-100">
        <header>
            <nav class="navbar navbar-expand-sm border-bottom shadow-sm mb-3">
                <div class="container-fluid">
                    <a class="navbar-brand" asp-area="" asp-controller="Products" asp-action="Index">
                        DataTable Razor Htmx
                    </a>

                    <button id="theme-toggle" class="btn btn-outline-secondary" type="button">
                        <i class="bi bi-sun-fill d-dark-none"></i>
                        <i class="bi bi-moon-fill d-light-none"></i>
                    </button>
                </div>
            </nav>
        </header>

        @* Le conteneur main prend tout l'espace restant (flex-grow-1) *@
        <main role="main" class="container flex-grow-1 pb-3">
            @RenderBody()
        </main>

        <footer class="footer border-top">
            <div class="container text-center">
                <span class="text-muted">
                    &copy; 2026 - test du composant DataTable -
                    <a asp-area="" asp-controller="Products" asp-action="Index">Catalogue</a>
                </span>
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/htmx.org@1.9.10"></script>
    <script src="https://unpkg.com/idiomorph/dist/idiomorph.min.js"></script>

    <script src="~/dist/main.bundle.js" asp-append-version="true" defer></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>