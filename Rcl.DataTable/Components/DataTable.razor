@typeparam TItem
@typeparam TKey
@using Rcl.DataTable.Models
@using Microsoft.AspNetCore.Components.Routing
@inject NavigationManager Navigation

@if (Model != null)
{
    <div class="dt-container" id="dt-@Model.TableId" hx-ext="morph" hx-swap="morph">

        @if (Model.Search.IsVisible && !string.IsNullOrEmpty(Model.Search.SearchUrl))
        {
            <DataTableSearch TableId="@Model.TableId" Model="@Model.Search" TotalFound="@Model.FilteredCount" />
        }

        <div class="table-responsive">
            <table class="table-custom">
                <thead>
                    <tr>
                        @foreach (var col in Model.Columns)
                        {
                            <th hx-get="@Model.GetSortUrl(col.Item2)" hx-target="#dt-@Model.TableId"
                                class="user-select-none clickable-header">
                                <div class="header-content">
                                    <span>@col.Item1</span>
                                    @if (Model.SortColumn == col.Item2)
                                    {
                                        <i class="bi @(Model.IsAsc ? "bi-sort-up" : "bi-sort-down")"></i>
                                    }
                                </div>
                            </th>
                        }
                        @if (Model.HasActionButton)
                        {
                            <th class="col-actions-header">Actions</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        var actions = GetActions?.Invoke(item) ?? new List<TableAction>();
                        var detailUrl = actions.FirstOrDefault(a => !a.IsDelete)?.Url;
                        var isSelected = Model.SelectedId?.Equals(Model.GetKey(item)) ?? false;

                        <tr class="clickable-row @(isSelected ? "active" : "")"
                            onclick="if (!event.target.closest('.actions-wrapper')) { window.location.href='@detailUrl'; }">

                            @foreach (var col in Model.Columns)
                            {
                                <td>@Model.GetFormattedValue(item, col.Item2)</td>
                            }

                            @if (Model.HasActionButton)
                            {
                                <td class="col-actions-cell">
                                    <DataTableActions Actions="actions" />
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="dt-footer">
            <div class="page-size-selector">
                <span class="text-muted-small">Afficher</span>
                <select class="dt-select" name="pageSize"
                        hx-get="@Model.GetPageUrl(1).Split('?')[0]" 
                        hx-target="#dt-@Model.TableId" 
                        hx-swap="outerHTML"
                        hx-trigger="change">
                    @foreach (var option in Model.PageSizeOptions)
                    {
                        <option value="@option" selected="@(Model.PageSize == option)">@option</option>
                    }
                </select>
                <span class="text-muted-small">lignes / page</span>
            </div>

            <div class="pagination-wrapper">
                <div class="pagination-group">
                    @* Premier *@
                    <button class="pagination-btn" hx-get="@Model.GetPageUrl(1)"
                            hx-target="#dt-@Model.TableId" hx-swap="outerHTML" title="Premier">
                        <i class="bi bi-chevron-bar-left"></i>
                    </button>

                    @* Reculer de 10 *@
                    @{ var prevBlock = Math.Max(1, Model.CurrentPage - 10); }
                    <button class="pagination-btn d-hide-mobile" hx-get="@Model.GetPageUrl(prevBlock)"
                            hx-target="#dt-@Model.TableId" hx-swap="outerHTML" 
                            disabled="@(Model.CurrentPage <= 1)">
                        <i class="bi bi-chevron-double-left"></i>
                    </button>

                    @* Précédent *@
                    <button class="pagination-btn" hx-get="@Model.GetPageUrl(Model.CurrentPage - 1)"
                            hx-target="#dt-@Model.TableId" hx-swap="outerHTML" 
                            disabled="@(Model.CurrentPage <= 1)">
                        <i class="bi bi-chevron-left"></i>
                    </button>

                    <span class="page-info">@Model.GetInfoPagePositionFormattedValue()</span>

                    @* Suivant *@
                    <button class="pagination-btn" hx-get="@Model.GetPageUrl(Model.CurrentPage + 1)"
                            hx-target="#dt-@Model.TableId" hx-swap="outerHTML"
                            disabled="@(Model.CurrentPage >= Model.TotalPages)">
                        <i class="bi bi-chevron-right"></i>
                    </button>

                    @* Avancer de 10 *@
                    @{ var nextBlock = Math.Min(Model.TotalPages, Model.CurrentPage + 10); }
                    <button class="pagination-btn d-hide-mobile" hx-get="@Model.GetPageUrl(nextBlock)"
                            hx-target="#dt-@Model.TableId" hx-swap="outerHTML"
                            disabled="@(Model.CurrentPage >= Model.TotalPages)">
                        <i class="bi bi-chevron-double-right"></i>
                    </button>

                    @* Dernier *@
                    <button class="pagination-btn" hx-get="@Model.GetPageUrl(Model.TotalPages)"
                            hx-target="#dt-@Model.TableId" hx-swap="outerHTML" title="Dernier">
                        <i class="bi bi-chevron-bar-right"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public DataTableViewModel<TItem, TKey>? Model { get; set; }
    [Parameter] public Func<TItem, List<TableAction>>? GetActions { get; set; }
}