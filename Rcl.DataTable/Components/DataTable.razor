@typeparam TItem
@typeparam TKey
@using Rcl.DataTable.Models

@if (Model != null)
{
    <div class="dt-container" id="dt-prod-grid" hx-ext="morph" hx-target="this" hx-swap="outerHTML">

        <div class="dt-header-area">
            <div class="dt-length">
                @* name="pageSize" couplé à hx-include="this" permet à l'action Index de recevoir la valeur *@
                <select name="pageSize" 
                        hx-get="/Products/Index" 
                        hx-trigger="change" 
                        hx-include="this">
                    @foreach (var opt in Model.PageSizeOptions)
                    {
                        <option value="@opt" selected="@(Model.PageSize == opt)">@opt</option>
                    }
                </select>
                <span class="ms-2 text-muted">entrées par page</span>
            </div>
            <DataTableSearch TableId="dt-prod-grid" Model="@Model.Search" TotalFound="@Model.TotalItems" />
        </div>

        <div class="table-responsive">
            <table class="table-custom">
                <thead>
                    <tr>
                        @* Le triangle n'est affiché que si des colonnes secondaires existent *@
                        @if (Model.Columns.Any(c => c.IsSecondary)) {
                            <th class="dtr-control-header d-xl-none"></th>
                        }
                        @foreach (var col in Model.Columns) {
                            <th class="@col.ResponsiveClass" hx-get="@Model.GetSortUrl(col.Prop)">@col.Display</th>
                        }
                        @* Barre d'outils toujours visible sur PC (XL) *@
                        <th class="d-none d-xl-table-cell">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        var rowId = Model.GetKey(item).ToString();
                        var isExpanded = Model.ExpandedRows.Contains(rowId);
                        var hasSecondary = Model.Columns.Any(c => c.IsSecondary);

                        <tr class="@(isExpanded ? "dtr-expanded" : "")">
                            @if (hasSecondary) {
                                <td class="dtr-control d-xl-none" 
                                    hx-get="/Products/ToggleRow?id=@rowId&page=@Model.CurrentPage&sort=@Model.SortColumn&isAsc=@Model.IsAsc&searchTerm=@Model.Search.SearchTerm">
                                </td>
                            }
                            @foreach (var col in Model.Columns) {
                                <td class="@col.ResponsiveClass">@Model.GetFormattedValue(item, col.Prop)</td>
                            }
                            @* Actions en ligne pour le plein écran *@
                            <td class="d-none d-xl-table-cell">
                                <DataTableActions Actions="@GetActions(item)" />
                            </td>
                        </tr>

                        @if (isExpanded && hasSecondary)
                        {
                            @* tr-child masqué sur XL car tout y est affiché en ligne *@
                            <tr class="child d-xl-none">
                                <td colspan="@(Model.Columns.Count + 1)">
                                    <div class="dtr-details-container">
                                        <ul class="dtr-details">
                                            @foreach (var col in Model.Columns.Where(c => c.IsSecondary))
                                            {
                                                @* LOGIQUE DE FLUIDITÉ : 
                                                   On inverse la classe. Si la colonne s'affiche en md, 
                                                   on la cache ici en md pour éviter les doublons. *@
                                                <li class="dtr-item @col.ResponsiveClass.Replace("d-md-table-cell", "d-md-none").Replace("d-lg-table-cell", "d-lg-none")">
                                                    <span class="dtr-title">@col.Display</span>
                                                    <span class="dtr-data">@Model.GetFormattedValue(item, col.Prop)</span>
                                                </li>
                                            }
                                        </ul>
                                        <div class="dtr-actions-inline">
                                            <DataTableActions Actions="@GetActions(item)" />
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="dt-footer">
            <div class="dt-info">@Model.GetInfoPagePositionFormattedValue()</div>
            <div class="pagination-group">
                <button class="pagination-btn" hx-get="@Model.GetPageUrl(1)">«</button>
                <button class="pagination-btn @(Model.CurrentPage == 1 ? "disabled" : "")" 
                        hx-get="@Model.GetPageUrl(Model.CurrentPage - 1)" 
                        @(Model.CurrentPage == 1 ? "disabled" : "")>‹</button>
                <span class="pagination-number active">@Model.CurrentPage</span>
                <button class="pagination-btn @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")" 
                        hx-get="@Model.GetPageUrl(Model.CurrentPage + 1)" 
                        @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")>›</button>
                <button class="pagination-btn" hx-get="@Model.GetPageUrl(Model.TotalPages)">»</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired] public DataTableViewModel<TItem, TKey>? Model { get; set; }
    [Parameter] public Func<TItem, List<TableAction>>? GetActions { get; set; }
}