@typeparam TItem
@typeparam TKey
@using Rcl.DataTable.Models
@inject NavigationManager Navigation

@if (Model != null)
{
    <div class="dt-container" id="dt-@Model.TableId" hx-ext="morph" hx-swap="morph">

        @if (Model.Search.IsVisible && !string.IsNullOrEmpty(Model.Search.SearchUrl))
        {
            <DataTableSearch TableId="@Model.TableId" Model="@Model.Search" TotalFound="@Model.FilteredCount" />
        }

        <div class="table-responsive">
            <table class="table-custom">
                <thead>
                    <tr>
                        @foreach (var col in Model.Columns)
                        {
                            @* On applique d-hide-mobile si la colonne est la référence (supposée col 0 ou nom spécifique) *@
                            <th hx-get="@Model.GetSortUrl(col.Item2)" hx-target="#dt-@Model.TableId"
                                class="user-select-none clickable-header @(col.Item1.Contains("Référence") ? "d-hide-mobile" : "")">
                                <div class="header-content">
                                    <span>@col.Item1</span>
                                    @if (Model.SortColumn == col.Item2)
                                    {
                                        <i class="bi @(Model.IsAsc ? "bi-sort-up" : "bi-sort-down")"></i>
                                    }
                                </div>
                            </th>
                        }
                        @if (Model.HasActionButton)
                        {
                            <th class="col-actions-header">Actions</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        var actions = GetActions?.Invoke(item) ?? new List<TableAction>();
                        var detailUrl = actions.FirstOrDefault(a => !a.IsDelete)?.Url;
                        var isSelected = Model.SelectedId?.Equals(Model.GetKey(item)) ?? false;

                        <tr class="clickable-row @(isSelected ? "active" : "")"
                            onclick="if (!event.target.closest('.actions-wrapper')) { window.location.href='@detailUrl'; }">

                            @foreach (var col in Model.Columns)
                            {
                                <td class="@(col.Item1.Contains("Référence") ? "d-hide-mobile" : "")">
                                    @Model.GetFormattedValue(item, col.Item2)
                                </td>
                            }

                            @if (Model.HasActionButton)
                            {
                                <td class="col-actions-cell">
                                    <div class="actions-wrapper">
                                        @foreach (var action in actions)
                                        {
                                            @if (action.IsDelete)
                                            {
                                                <button class="action-btn btn-delete" 
                                                        hx-delete="@action.Url" 
                                                        hx-confirm="Confirmer la suppression ?"
                                                        hx-target="#dt-@Model.TableId">
                                                    <i class="bi bi-trash3"></i>
                                                </button>
                                            }
                                            else
                                            {
                                                <a href="@action.Url" class="action-btn btn-edit">
                                                    <i class="bi bi-pencil-square"></i>
                                                </a>
                                            }
                                        }
                                    </div>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="dt-footer">
            <div class="page-size-selector">
                <span class="text-muted-small">Afficher</span>
                <select class="dt-select" name="pageSize"
                        hx-get="@Model.GetPageUrl(1).Split('?')[0]" 
                        hx-target="#dt-@Model.TableId" 
                        hx-swap="outerHTML"
                        hx-trigger="change">
                    @foreach (var option in Model.PageSizeOptions)
                    {
                        <option value="@option" selected="@(Model.PageSize == option)">@option</option>
                    }
                </select>
                <span class="text-muted-small d-hide-mobile">lignes / page</span>
            </div>

            <div class="pagination-wrapper">
                <div class="pagination-group">
                    <button class="pagination-btn" hx-get="@Model.GetPageUrl(1)" hx-target="#dt-@Model.TableId" title="Premier">
                        <i class="bi bi-chevron-bar-left"></i>
                    </button>

                    <button class="pagination-btn d-hide-mobile" hx-get="@Model.GetPageUrl(Math.Max(1, Model.CurrentPage - 10))"
                            hx-target="#dt-@Model.TableId" disabled="@(Model.CurrentPage <= 1)">
                        <i class="bi bi-chevron-double-left"></i>
                    </button>

                    <button class="pagination-btn" hx-get="@Model.GetPageUrl(Model.CurrentPage - 1)"
                            hx-target="#dt-@Model.TableId" disabled="@(Model.CurrentPage <= 1)">
                        <i class="bi bi-chevron-left"></i>
                    </button>

                    <span class="page-info">@Model.GetInfoPagePositionFormattedValue()</span>

                    <button class="pagination-btn" hx-get="@Model.GetPageUrl(Model.CurrentPage + 1)"
                            hx-target="#dt-@Model.TableId" disabled="@(Model.CurrentPage >= Model.TotalPages)">
                        <i class="bi bi-chevron-right"></i>
                    </button>

                    <button class="pagination-btn d-hide-mobile" hx-get="@Model.GetPageUrl(Math.Min(Model.TotalPages, Model.CurrentPage + 10))"
                            hx-target="#dt-@Model.TableId" disabled="@(Model.CurrentPage >= Model.TotalPages)">
                        <i class="bi bi-chevron-double-right"></i>
                    </button>

                    <button class="pagination-btn" hx-get="@Model.GetPageUrl(Model.TotalPages)" hx-target="#dt-@Model.TableId" title="Dernier">
                        <i class="bi bi-chevron-bar-right"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public DataTableViewModel<TItem, TKey>? Model { get; set; }
    [Parameter] public Func<TItem, List<TableAction>>? GetActions { get; set; }
}