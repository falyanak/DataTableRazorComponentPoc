{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "ts-build",
            "type": "shell",
            "command": "node esbuild.config.js", 
            "options": {
                "cwd": "${workspaceFolder}/WebApp.Client"
            },
            "problemMatcher": []
        },
        {
            "label": "ts-check",
            "type": "shell",
            "command": "npx tsc --noEmit",
            "options": {
                "cwd": "${workspaceFolder}/WebApp.Client"
            },
            "problemMatcher": "$tsc"
        },
        {
            "label": "dotnet-build",
            "type": "process",
            "command": "dotnet",
            "args": [
                "build",
                "${workspaceFolder}/WebApp.Client/WebApp.Client.csproj"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "FULL-BUILD",
            "dependsOrder": "sequence",
            "dependsOn": [
                "ts-build",    // <--- ON GÉNÈRE LE BUNDLE ICI
                "ts-check",
                "dotnet-build"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}